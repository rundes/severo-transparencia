# --- API electoral DINE ---
# getResultados es ABIERTO (sin token). Base por defecto ya configurada en el código.
DINE_API_BASE=https://resultados.mininterior.gob.ar/api
# Cookie de routing del backend (algunas instancias la requieren).
DINE_ROUTING_COOKIE=be_resultados=dine-elecciones-02
# Bearer token OPCIONAL: solo necesario para desbloquear getMenu (árbol de catálogos).
# Dejar vacío mientras se usan catálogos seedeados.
DINE_BEARER_TOKEN=

# --- Caché ---
# Dir para la caché persistente de agregaciones (comparar/agrupaciones).
# Default: <tmpdir>/severo-transparencia-cache. En self-host conviene un path estable.
CACHE_DIR=

# --- IA (Claude) ---
ANTHROPIC_API_KEY=
# Modelo por defecto para preguntas/informes.
ANTHROPIC_MODEL=claude-opus-4-8

# --- BigQuery (datos electorales extra, opcional) ---
# Si se configura, la IA puede consultar el proyecto vía SQL de solo lectura.
GCP_PROJECT_ID=cp-electoral
# JSON del service account (pegar el contenido del key.json) o su base64.
# Roles necesarios: BigQuery Data Viewer + BigQuery Job User.
GCP_SERVICE_ACCOUNT_KEY=
# Opcional: región de los datasets si no es la default (ej: southamerica-east1).
GCP_BQ_LOCATION=
